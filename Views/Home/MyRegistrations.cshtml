@model List<CampusActivitySystem.Models.Registration>
@{
    ViewData["Title"] = "我的报名";
}

<h3 class="mb-4"><i class="bi bi-journal-check"></i> 我的报名记录</h3>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">暂无报名记录，去<a asp-controller="Activity" asp-action="Index">活动列表</a>报名吧！</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>活动名称</th>
                    <th>状态</th>
                    <th>报名时间</th>
                    <th>签到</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in Model)
                {
                    <tr>
                        <td>
                            @if (reg.Activity != null)
                            {
                                <a asp-controller="Activity" asp-action="Detail" asp-route-id="@reg.ActivityId">@reg.Activity.Title</a>
                            }
                            else
                            {
                                <span>(活动已删除)</span>
                            }
                        </td>
                        <td>
                            @switch (reg.Status)
                            {
                                case "REGISTERED":
                                    <span class="badge bg-success">已报名</span>
                                    break;
                                case "PENDING":
                                    <span class="badge bg-warning text-dark">待审核</span>
                                    break;
                                case "CHECKED_IN":
                                    <span class="badge bg-info">已签到</span>
                                    break;
                                case "CANCELLED":
                                    <span class="badge bg-secondary">已取消</span>
                                    break;
                                case "REJECTED":
                                    <span class="badge bg-danger">已拒绝</span>
                                    break;
                                default:
                                    <span class="badge bg-light text-dark">@reg.Status</span>
                                    break;
                            }
                        </td>
                        <td>@reg.RegisteredAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (reg.Status == "CHECKED_IN")
                            {
                                <span class="badge bg-success">已签到</span>
                            }
                            else if (reg.Status == "REGISTERED")
                            {
                                <span class="badge bg-warning text-dark">未签到</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (reg.Status == "REGISTERED" || reg.Status == "PENDING")
                            {
                                <form asp-controller="Registration" asp-action="Cancel" method="post"
                                      onsubmit="return confirm('确定要取消报名【@reg.Activity?.Title】吗？');">
                                    <input type="hidden" name="registrationId" value="@reg.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">取消报名</button>
                                </form>
                                @if (reg.Status == "CANCELLED" || reg.Status == "REJECTED")
                                {
                                    <form asp-controller="Registration" asp-action="Register" method="post" class="mt-1">
                                        <input type="hidden" name="activityId" value="@reg.ActivityId" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">重新报名</button>
                                    </form>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}