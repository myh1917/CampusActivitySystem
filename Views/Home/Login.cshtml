            <div class="card-body p-4 p-md-5">
                <h2 class="text-center mb-4 fw-bold" style="color: #667eea;">
                    <i class="bi bi-person-circle display-5"></i>
                </h2>
                <h4 class="text-center mb-4">УГ»§µЗВј</h4>

                 @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @Html.ValidationSummary(false)
                    </div>
                }

                <form method="post" action="/Account/Login">
                    <div class="mb-3">
                        <label class="form-label">ХЛєЕ</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input type="text" name="account" class="form-control" placeholder="ЗлКдИлС§єЕ»тХЛєЕ" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">ГЬВл</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input type="password" name="password" class="form-control" placeholder="ЗлКдИлГЬВл" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2 mt-2">µЗ Вј</button>
                </form>
                <div class="text-center mt-3">
                    <p class="text-muted">»№Г»УРХЛєЕЈї <a href="/Home/Register">БўјґЧўІб</a></p>
                </div>
            </div>
        </div>
    </div>
</div>