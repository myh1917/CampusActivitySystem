@using CampusActivitySystem.Models.ViewModels
@model MyActivitiesViewModel
@{
    ViewData["Title"] = "我的活动";
    var userName = Context.Session.GetString("UserName") ?? "用户";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold"><i class="bi bi-clipboard-check"></i> 我发布的活动</h3>
        <p class="text-muted mb-0">管理您发布的所有活动，编辑信息、查看签到数据</p>
    </div>
    <a asp-controller="Activity" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> 发布新活动
    </a>
</div>

@if (Model.TotalActivities == 0)
{
    <!-- 空状态 -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body text-center py-5">
            <i class="bi bi-megaphone display-1 text-muted"></i>
            <h5 class="mt-3 text-muted">您还没有发布任何活动</h5>
            <p class="text-muted">点击「发布新活动」开始创建您的第一个校园活动</p>
            <a asp-controller="Activity" asp-action="Create" class="btn btn-primary mt-2">
                <i class="bi bi-plus-circle"></i> 发布新活动
            </a>
        </div>
    </div>
}
else
{
    <!-- 统计卡片 — 全部使用真实数据 -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary shadow-sm rounded-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">发布活动</h6>
                        <h2 class="mt-2 mb-0">@Model.TotalActivities</h2>
                    </div>
                    <i class="bi bi-megaphone display-4 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success shadow-sm rounded-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">总签到人次</h6>
                        <h2 class="mt-2 mb-0">@Model.TotalSignIns</h2>
                    </div>
                    <i class="bi bi-check-circle display-4 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info shadow-sm rounded-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">总报名人次</h6>
                        <h2 class="mt-2 mb-0">@Model.TotalRegistrations</h2>
                    </div>
                    <i class="bi bi-people display-4 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white @(Model.NeedsAttention > 0 ? "bg-warning" : "bg-secondary") shadow-sm rounded-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">需要关注</h6>
                        <h2 class="mt-2 mb-0">@Model.NeedsAttention</h2>
                    </div>
                    <i class="bi bi-exclamation-triangle display-4 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- 活动列表表格 -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>活动名称</th>
                            <th>类别</th>
                            <th>报名人数</th>
                            <th>签到率</th>
                            <th>状态</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var act in Model.Activities)
                        {
                            var signRate = act.RegisteredCount > 0
                                ? (int)Math.Round(act.SignedCount * 100.0 / act.RegisteredCount)
                                : 0;
                            var statusClass = act.Status switch
                            {
                                "PUBLISHED" => "bg-success",
                                "DRAFT" => "bg-warning text-dark",
                                _ => "bg-secondary"
                            };
                            var statusText = act.Status switch
                            {
                                "PUBLISHED" => "进行中",
                                "DRAFT" => "草稿",
                                _ => act.Status
                            };

                            <tr>
                                <td>
                                    <a asp-controller="Activity" asp-action="Detail" asp-route-id="@act.Id"
                                       class="text-decoration-none fw-semibold">
                                        @act.Title
                                    </a>
                                    @if (act.PendingAuditCount > 0)
                                    {
                                        <span class="badge bg-warning text-dark ms-1" title="有待审核报名">
                                            @act.PendingAuditCount 待审
                                        </span>
                                    }
                                </td>
                                <td><span class="badge bg-light text-dark">@(string.IsNullOrEmpty(act.Category) ? "未分类" : act.Category)</span></td>
                                <td>@act.RegisteredCount@(act.Capacity > 0 ? $"/{act.Capacity}" : "")</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="progress flex-grow-1" style="height:6px; min-width:50px;">
                                            <div class="progress-bar @(signRate >= 80 ? "bg-success" : signRate >= 50 ? "bg-info" : "bg-warning")"
                                                 role="progressbar"
                                                 style="width:@signRate%;">
                                            </div>
                                        </div>
                                        <span class="ms-2 small text-muted">@signRate%</span>
                                    </div>
                                </td>
                                <td><span class="badge @statusClass">@statusText</span></td>
                                <td>
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                                data-bs-toggle="dropdown" aria-expanded="false">
                                            管理
                                        </button>
                                        <ul class="dropdown-menu">
                                            <li>
                                                <a class="dropdown-item"
                                                   asp-controller="Activity" asp-action="Edit" asp-route-id="@act.Id">
                                                    <i class="bi bi-pencil"></i> 编辑信息
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item"
                                                   asp-controller="SignIn" asp-action="Control" asp-route-activityId="@act.Id">
                                                    <i class="bi bi-qr-code"></i> 签到控制台
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item"
                                                   asp-controller="Statistics" asp-action="Index" asp-route-activityId="@act.Id">
                                                    <i class="bi bi-bar-chart"></i> 统计导出
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- 页面底部统计提示 -->
    <div class="text-muted small mt-3">
        共 <strong>@Model.TotalActivities</strong> 个活动，
        累计 <strong>@Model.TotalRegistrations</strong> 人次报名，
        <strong>@Model.TotalSignIns</strong> 人次签到
    </div>
}
