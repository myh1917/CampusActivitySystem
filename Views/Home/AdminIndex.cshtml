        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr><th>姓名</th><th>学号</th><th>角色</th><th>状态</th><th>操作</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td>小明</td>
                        <td>2024001</td>
                        <td>学生</td>
                        <td><span class="badge bg-success">启用</span></td>
                        <td><button class="btn btn-sm btn-outline-secondary">编辑</button></td>
                    </tr>
                    <tr>
                        <td>张老师</td>
                        <td>T001</td>
                        <td>活动负责人</td>
                        <td><span class="badge bg-success">启用</span></td>
                        <td><button class="btn btn-sm btn-outline-secondary">编辑</button></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>