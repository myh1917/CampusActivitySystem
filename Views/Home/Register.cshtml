@{
    ViewData["Title"] = "зЂВс";
}

@if (TempData["RegisterSuccess"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill"></i> @TempData["RegisterSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4 p-md-5">
                <h4 class="text-center mb-4"><i class="bi bi-person-plus-fill" style="color:#667eea;"></i> еЫКХзЂВс</h4>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @Html.ValidationSummary(false)
                    </div>
                }

                @if (ViewBag.AllowRegister != null && !(bool)ViewBag.AllowRegister)
                {
                    <div class="alert alert-warning text-center">
                        <i class="bi bi-exclamation-triangle"></i> зЂВсЙІФмвбЙиБеЃЌЧыСЊЯЕЙмРэдБЁЃ
                    </div>
                }

                <form method="post" action="/Account/Register">
                    <div class="mb-3">
                        <label class="form-label">НЧЩЋ</label>
                        <select name="role" class="form-select" required>
                            <option value="student">бЇЩњ</option>
                            <option value="organizer">ЛюЖЏИКд№ШЫ</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">бЇКХ / ЙЄКХ</label>
                        <input type="text" name="studentNo" class="form-control" placeholder="ЧыЪфШыбЇКХЛђЙЄКХ" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">аеУћ</label>
                        <input type="text" name="name" class="form-control" placeholder="ЧыЪфШыецЪЕаеУћ" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">еЫКХ</label>
                        <input type="text" name="account" class="form-control" placeholder="ЩшжУЕЧТМеЫКХ" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">УмТы</label>
                        <input type="password" name="password" class="form-control" placeholder="жСЩй8ЮЛ" required minlength="8">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">ЪжЛњКХ</label>
                        <input type="text" name="phone" class="form-control" placeholder="бЁЬю">
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2" @(ViewBag.AllowRegister == false ? "disabled" : "")>зЂ Вс</button>
                </form>
                <div class="text-center mt-3">
                    <p class="text-muted">вбгаеЫКХЃП <a href="/Account/Login">СЂМДЕЧТМ</a></p>
                </div>
            </div>
        </div>
    </div>
</div>