@{
    ViewData["Title"] = "活动签到";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body text-center p-5">
                <h3 class="mb-3"><i class="bi bi-check-circle-fill text-success display-4"></i></h3>
                <h4>活动签到</h4>
                <p class="text-muted">请输入6位签到码或扫描二维码</p>
                <div class="mb-3">
                    <input type="text" id="signCodeInput" class="form-control form-control-lg text-center" placeholder="输入签到码" maxlength="6">
                </div>
                <button id="signBtn" class="btn btn-primary btn-lg w-100">立即签到</button>
                <hr>
                <p class="text-muted">或扫描二维码</p>
                <!-- 二维码占位图 -->
                <div class="border rounded p-3 d-inline-block">
                    <i class="bi bi-qr-code display-1 text-muted"></i>
                    <p class="small mt-2">二维码区域</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 签到成功 Toast -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="successToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="bi bi-check-circle-fill me-2"></i> 签到成功！欢迎参加活动。
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<!-- 签到失败 Toast -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="errorToast" class="toast align-items-center text-bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="bi bi-exclamation-octagon-fill me-2"></i> 签到失败：<span id="errorMsg">签到码无效</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<script>// ========== 模拟签到逻辑 ==========
    // 正式开发时，用 fetch 向后台发送签到请求，根据返回结果调用 showSuccessToast() 或 showErrorToast()
    document.getElementById('signBtn').addEventListener('click', function() {
        var code = document.getElementById('signCodeInput').value.trim();
        if (code.length !== 6) {
            showErrorToast("请输入6位签到码");
            return;
        }
        // 模拟随机成功或失败（为了预览）
        var isSuccess = Math.random() > 0.3; // 70% 成功
        if (isSuccess) {
            showSuccessToast();
        } else {
            showErrorToast("签到码错误或活动已结束");
        }
    });

    function showSuccessToast() {
        var toast = new bootstrap.Toast(document.getElementById('successToast'));
        toast.show();
    }

    function showErrorToast(message) {
        document.getElementById('errorMsg').textContent = message;
        var toast = new bootstrap.Toast(document.getElementById('errorToast'));
        toast.show();
    }</script>