@model List<CampusActivitySystem.Models.Activity>
@{
    ViewData["Title"] = "首页";
    var userIdStr = Context.Session.GetString("UserId");
    long currentUserId = 0;
    long.TryParse(userIdStr, out currentUserId);
    var rolesStr = Context.Session.GetString("Roles") ?? "";
    bool isAdmin = rolesStr.Contains("admin");
    bool isOrganizer = rolesStr.Contains("organizer");
}

<!-- 欢迎区域 -->
<div class="p-5 mb-4 rounded-3 text-white" style="background: linear-gradient(135deg, #667eea, #764ba2);">
    <div class="container-fluid py-5">
        <h1 class="display-5 fw-bold"><i class="bi bi-calendar-check"></i> 校园活动报名与签到系统</h1>
        <p class="col-md-8 fs-4">发现身边精彩活动，一键报名、快速签到，让你的校园生活更有序！</p>
    </div>
</div>

<!-- 活动卡片列表 -->
<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 border-0 shadow-sm card-clickable">
                    <a asp-controller="Activity" asp-action="Detail" asp-route-id="@item.Id" class="card-link-cover"></a>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title">@item.Title</h5>
                            <span class="badge bg-primary">@item.Category</span>
                        </div>
                        <p class="card-text text-muted">
                            <i class="bi bi-geo-alt"></i> @item.Location<br>
                            <i class="bi bi-clock"></i> @item.StartTime.ToString("yyyy-MM-dd HH:mm")
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge @((item.RegisteredCount >= item.Capacity) ? "bg-danger" : "bg-success")">
                                @item.RegisteredCount / @item.Capacity
                            </span>
                            <div style="position:relative; z-index:2;">
                                <a asp-controller="Activity" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm me-1">查看详情</a>
                                @if (isAdmin || (isOrganizer && item.OrganizerId == currentUserId))
                                {
                                    <a asp-controller="Activity" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">编辑</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info">暂时没有活动，请等待管理员或活动负责人发布。</div>
        </div>
    }
</div>