@{
    ViewData["Title"] = "活动列表";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-calendar-event"></i> 全部活动</h2>
    <a href="#" class="btn btn-primary"><i class="bi bi-plus-circle"></i> 发布活动</a>
</div>

<!-- 搜索筛选 -->
<div class="row mb-4">
    <div class="col-md-6 mb-2">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="搜索活动名称...">
            <button class="btn btn-primary" type="button">搜索</button>
        </div>
    </div>
    <div class="col-md-3 mb-2">
        <select class="form-select">
            <option>全部类别</option>
            <option>讲座</option>
            <option>竞赛</option>
            <option>社团活动</option>
        </select>
    </div>
    <div class="col-md-3 mb-2">
        <select class="form-select">
            <option>全部状态</option>
            <option>报名中</option>
            <option>未开始</option>
            <option>已结束</option>
        </select>
    </div>
</div>

<!-- 活动卡片网格（重复示例） -->
<div class="row">
    <!-- 卡片模板，实际开发中用循环 -->
    @for (int i = 1; i <= 6; i++) {
    <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
                <span class="badge bg-primary float-end">讲座</span>
                <h5 class="card-title">人工智能与未来 @i</h5>
                <p class="card-text text-muted">
                    <i class="bi bi-geo-alt"></i> 教学楼A101<br>
                    <i class="bi bi-clock"></i> 2026-06-12 14:00
                </p>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="badge bg-success"><i class="bi bi-people"></i> 23/50</span>
                    <a href="/Home/ActivityDetail" class="btn btn-outline-primary btn-sm">查看详情</a>
                </div>
            </div>
        </div>
    </div>
    }
</div>

<!-- 分页占位 -->
<nav class="mt-4">
    <ul class="pagination justify-content-center">
        <li class="page-item disabled"><a class="page-link" href="#">上一页</a></li>
        <li class="page-item active"><a class="page-link" href="#">1</a></li>
        <li class="page-item"><a class="page-link" href="#">2</a></li>
        <li class="page-item"><a class="page-link" href="#">3</a></li>
        <li class="page-item"><a class="page-link" href="#">下一页</a></li>
    </ul>
</nav>