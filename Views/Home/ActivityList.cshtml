@model List<CampusActivitySystem.Models.Activity>
@{
    ViewData["Title"] = "活动列表";
}

<!-- 显示操作结果消息 -->
@if (TempData["Success"] != null)
{
        <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
}
@if (TempData["Error"] != null)
{
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-calendar-event"></i> 全部活动</h2>
    <a asp-action="Create" asp-controller="Activity" class="btn btn-primary"><i class="bi bi-plus-circle"></i> 发布活动</a>
</div>

<!-- 搜索筛选 -->
<form asp-action="Index" asp-controller="Activity" method="get">
    <div class="row mb-4">
        <div class="col-md-6 mb-2">
            <div class="input-group">
                <input type="text" name="keyword" class="form-control" placeholder="搜索活动名称..." value="@Context.Request.Query["keyword"]">
                <button class="btn btn-primary" type="submit">搜索</button>
            </div>
        </div>
        <div class="col-md-3 mb-2">
            <select name="category" class="form-select">
                <option value="">全部类别</option>
                <option value="讲座" selected="@(Context.Request.Query["category"] == "讲座" ? "selected" : null)">讲座</option>
                <option value="竞赛" selected="@(Context.Request.Query["category"] == "竞赛" ? "selected" : null)">竞赛</option>
                <option value="社团活动" selected="@(Context.Request.Query["category"] == "社团活动" ? "selected" : null)">社团活动</option>
                <option value="文体活动" selected="@(Context.Request.Query["category"] == "文体活动" ? "selected" : null)">文体活动</option>
                <option value="志愿服务" selected="@(Context.Request.Query["category"] == "志愿服务" ? "selected" : null)">志愿服务</option>
                <option value="学术研讨" selected="@(Context.Request.Query["category"] == "学术研讨" ? "selected" : null)">学术研讨</option>
                <option value="就业创业" selected="@(Context.Request.Query["category"] == "就业创业" ? "selected" : null)">就业创业</option>
                <option value="文艺演出" selected="@(Context.Request.Query["category"] == "文艺演出" ? "selected" : null)">文艺演出</option>
                <option value="体育运动" selected="@(Context.Request.Query["category"] == "体育运动" ? "selected" : null)">体育运动</option>
                <option value="其他" selected="@(Context.Request.Query["category"] == "其他" ? "selected" : null)">其他</option>
            </select>
        </div>
        <div class="col-md-3 mb-2">
            <!-- 状态筛选暂不实现 -->
        </div>
    </div>
</form>

<!-- 活动卡片网格 -->
<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="card-body">
                                <span class="badge bg-primary float-end">@item.Category</span>
                                <h5 class="card-title">@item.Title</h5>
                                <p class="card-text text-muted">
                                    <i class="bi bi-geo-alt"></i> @item.Location<br>
                                    <i class="bi bi-clock"></i> @item.StartTime.ToString("yyyy-MM-dd HH:mm")
                                </p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="badge bg-success"><i class="bi bi-people"></i> @item.RegisteredCount/@item.Capacity</span>
                                    <!-- 报名表单 -->
                                    <form asp-controller="Registration" asp-action="Register" method="post">
                                        <input type="hidden" name="activityId" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-primary btn-sm">立即报名</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
        }
    }
    else
    {
            <div class="col-12">
                <div class="alert alert-info">暂时没有活动，去发布一个吧！</div>
            </div>
    }
</div>
