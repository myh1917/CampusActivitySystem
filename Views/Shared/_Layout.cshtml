@using CampusActivitySystem.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext

@{
    var userId = Context.Session.GetString("UserId");
    var userName = Context.Session.GetString("UserName");
    var rolesStr = Context.Session.GetString("Roles");
    var isAdmin = rolesStr?.Contains("admin") == true;
    var isOrganizer = rolesStr?.Contains("organizer") == true;

    int unreadNotices = 0;
    if (!string.IsNullOrEmpty(userId) && long.TryParse(userId, out long uid))
    {
        unreadNotices = await DbContext.Notices.CountAsync(n => n.UserId == uid && !n.IsRead);
    }

    int pendingAudits = 0;
    if (isAdmin)
    {
        pendingAudits = await DbContext.Registrations.CountAsync(r => r.Status == "PENDING");
    }
    else if (isOrganizer && long.TryParse(userId, out long orgId))
    {
        pendingAudits = await DbContext.Registrations
            .CountAsync(r => r.Status == "PENDING" && r.Activity.OrganizerId == orgId);
    }
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 校园活动报名与签到系统</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg sticky-top" style="z-index: 1030; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="container">
            <a class="navbar-brand text-white fw-bold" href="/">
                <i class="bi bi-mortarboard-fill"></i> 校园活动报名与签到系统
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/"><i class="bi bi-house-door"></i> 首页</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Activity" asp-action="Index">
                            <i class="bi bi-list-ul"></i> 活动列表
                        </a>
                    </li>

                    @if (!string.IsNullOrEmpty(userId))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="SignIn" asp-action="Index">
                                <i class="bi bi-check2-square"></i> 签到
                            </a>
                        </li>

                        @if (isAdmin || isOrganizer)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white position-relative" asp-controller="Registration" asp-action="AuditList">
                                    <i class="bi bi-clipboard-check"></i> 审核
                                    @if (pendingAudits > 0)
                                    {
                                        <span class="badge bg-danger ms-1">@pendingAudits</span>
                                    }
                                </a>
                            </li>
                        }

                        @if (isAdmin || isOrganizer)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link text-white dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear"></i> 管理
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" style="z-index: 1040;">
                                    @if (isAdmin)
                                    {
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">后台首页</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="AdminUserList">用户管理</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="SystemConfigs">系统配置</a></li>
                                    }
                                    @if (isOrganizer || isAdmin)
                                    {
                                        <li><a class="dropdown-item" asp-controller="Activity" asp-action="Create">发布活动</a></li>
                                        <li><a class="dropdown-item" asp-controller="SignIn" asp-action="Control">签到控制台</a></li>
                                        <li><a class="dropdown-item" href="/Home/MyActivities">我的活动</a></li>
                                    }
                                    <li><a class="dropdown-item" asp-controller="Statistics" asp-action="Index">统计导出</a></li>
                                </ul>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link text-white position-relative" asp-controller="Notice" asp-action="Index">
                                <i class="bi bi-bell"></i> 通知
                                @if (unreadNotices > 0)
                                {
                                    <span class="badge bg-danger ms-1">@unreadNotices</span>
                                }
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link text-white dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @userName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" style="z-index: 1040;">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Info">个人信息</a></li>
                                <li><a class="dropdown-item" asp-controller="Registration" asp-action="MyRegistrations">我的报名</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Logout">退出登录</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> 登录
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus"></i> 注册
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-4 flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-dark text-white text-center py-3 mt-auto">
        <div class="container">
            <p class="mb-0">&copy; 2026 校园活动报名与签到系统 | 课程设计项目</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
