@{
    ViewData["Title"] = "活动签到";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <i class="bi bi-check-circle-fill text-success display-4"></i>
                    <h3 class="mt-2">活动签到</h3>
                    <p class="text-muted">输入负责人提供的6位签到码，或使用摄像头扫描二维码</p>
                </div>

                <form id="codeForm" asp-action="ByCode" method="post">
                    @Html.AntiForgeryToken()
                    <div class="input-group input-group-lg mb-3">
                        <input name="code" id="signCodeInput" inputmode="numeric" pattern="[0-9]{6}"
                               maxlength="6" class="form-control text-center" placeholder="请输入6位签到码" required />
                        <button class="btn btn-primary" type="submit">立即签到</button>
                    </div>
                </form>

                <div class="text-center my-4"><span class="text-muted">或</span></div>
                <button id="scanButton" class="btn btn-outline-primary w-100" type="button">
                    <i class="bi bi-camera"></i> 打开摄像头扫码
                </button>
                <div id="reader" class="mt-3 d-none"></div>
                <p class="small text-muted mt-2 mb-0">
                    浏览器摄像头需要 HTTPS 或 localhost；无法调用摄像头时仍可使用签到码。
                </p>
                <div id="resultAlert" class="alert mt-4 d-none" role="alert"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script>
        const form = document.getElementById('codeForm');
        const alertBox = document.getElementById('resultAlert');
        let scanner = null;

        function showResult(success, message) {
            alertBox.className = `alert mt-4 ${success ? 'alert-success' : 'alert-danger'}`;
            alertBox.textContent = message;
        }

        async function postForm(url, data) {
            const response = await fetch(url, {
                method: 'POST',
                headers: { 'RequestVerificationToken': form.querySelector('[name="__RequestVerificationToken"]').value },
                body: data
            });
            if (!response.ok) throw new Error('请求失败，请稍后重试');
            return response.json();
        }

        form.addEventListener('submit', async event => {
            event.preventDefault();
            const code = document.getElementById('signCodeInput').value.trim();
            if (!/^\d{6}$/.test(code)) return showResult(false, '请输入6位数字签到码');
            try {
                const result = await postForm(form.action, new FormData(form));
                showResult(result.success, result.message);
            } catch (error) {
                showResult(false, error.message);
            }
        });

        async function submitQr(decodedText) {
            let token = decodedText;
            try { token = new URL(decodedText).searchParams.get('token') || decodedText; } catch { }
            const data = new FormData();
            data.append('token', token);
            data.append('__RequestVerificationToken', form.querySelector('[name="__RequestVerificationToken"]').value);
            const result = await postForm('@Url.Action("ByQr", "SignIn")', data);
            showResult(result.success, result.message);
            if (result.success && scanner) await scanner.clear();
        }

        document.getElementById('scanButton').addEventListener('click', () => {
            const reader = document.getElementById('reader');
            reader.classList.remove('d-none');
            if (scanner) return;
            scanner = new Html5QrcodeScanner('reader', { fps: 10, qrbox: { width: 240, height: 240 } }, false);
            scanner.render(
                text => submitQr(text).catch(error => showResult(false, error.message)),
                () => { }
            );
        });
    </script>
}
