@model List<CampusActivitySystem.Models.Notice>
@{
    ViewData["Title"] = "通知中心";
}

<h3 class="mb-4"><i class="bi bi-bell"></i> 通知消息</h3>

@if (!Model.Any())
{
        <div class="alert alert-info">暂无通知</div>
}
else
{
        <div class="list-group shadow-sm rounded-4">
        @foreach (var notice in Model)
        {
                    <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-start @(!notice.IsRead ? "list-group-item-primary" : "")">
                        <div>
                            <div class="fw-bold">
                                <span class="badge bg-primary me-2">@notice.Type</span>
                        @notice.Title
                            </div>
                            <small class="text-muted">@notice.Content</small>
                        </div>
                        <small class="text-muted">@notice.CreatedAt.ToString("yyyy-MM-dd")</small>
                    </a>
        }
        </div>
}